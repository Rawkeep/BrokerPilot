# ==========================================================================
# BrokerPilot — Environment Variables
# Copy this to .env and fill in your values.
# ==========================================================================

# --- Supabase (Auth + Database + Storage) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- API URL (for GitHub Pages frontend → Railway backend) ---
# Leave empty for local dev (Vite proxy handles it)
VITE_API_URL=

# --- Email (choose one) ---
# Option 1: Resend (recommended, free tier: 100/day)
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com

# Option 2: SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=your@gmail.com

# --- Push Notifications (web-push VAPID keys) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- Server ---
PORT=3000
NODE_ENV=development
